# Copy to .env and adjust. Sourced by scripts/lib.sh and docker compose.

# Shared go-faster/fs S3 credentials (used by mimir/loki/tempo/greptimedb).
S3_ACCESS_KEY=bench
S3_SECRET_KEY=benchbench
S3_REGION=us-east-1

# Resource caps applied to oteldb (and a fair point of comparison to set on others).
BENCH_CPUS=        # empty = unconstrained (fair: all engines uncapped); set to cap oteldb
BENCH_MEMLIMIT=

# Benchmark runs per query (after warmup).
BENCH_RUNS=20

# Synthetic node_exporter hosts vmagent scrapes (metrics cardinality knob).
# Each host ≈ ~1.4k active series, so 1000 nodes ≈ ~1.4M series. benchctl
# regenerates config/vmagent/scrape.yml from this on `up` (metrics/all lanes).
BENCH_NODES=10

# Images (override to pin or to use locally built tags).
FS_IMAGE=ghcr.io/go-faster/fs:latest
OTELDB_IMAGE=ghcr.io/oteldb/oteldb:v0.41.0
GIGAPIPE_IMAGE=ghcr.io/metrico/gigapipe:latest

# Where the oteldb source checkout lives (for `otelbench` during ingest).
OTELDB_SRC=../oteldb

# Optional: directory of loghub .log files so the LogQL suite matches real data.
# LOGHUB_DIR=/path/to/loghub
